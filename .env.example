# Copy to .env. LLM inference runs entirely in-house via the `ollama` container
# (services/ai-service talks to it over the Docker network) — no external API
# keys required. Override the model pulled/served by ollama here if needed.

OLLAMA_MODEL=qwen3:14b

# M10 — Research Assistant's web-search tool (Brave Search API, free tier).
# Leave blank to disable web search: chat degrades to document/household-only
# grounding, same as before this milestone. Weather (Open-Meteo) needs no key
# at all. Get a free key at https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=
